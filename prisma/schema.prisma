datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────── Enums ───────────────────────

enum Role {
  USER
  AGENT
  ADMIN
}

enum ListingType {
  RENT
  SALE
}

enum PropertyType {
  APARTMENT
  HOUSE
  SHOP
  PLOT
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

// ─────────────────────── Models ──────────────────────

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?           // NextAuth OAuth avatar
  profileImage  String?           // Custom uploaded photo
  password      String?           // Bcrypt hashed
  phone         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  properties      Property[]
  bookings        Booking[]
  reviews         Review[]
  savedProperties SavedProperty[]
}

model Property {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String
  price        Float
  marla        Float
  city         String         @default("Peshawar")
  area         String
  address      String
  propertyType PropertyType
  subcategory  String         @default("")
  listingType  ListingType    @default(SALE)
  status       PropertyStatus @default(AVAILABLE)
  isApproved   Boolean        @default(true)
  bedrooms     Int            @default(0)
  bathrooms    Int            @default(0)
  imageUrls    String[]       // Cloudinary image URLs (array)
  videoUrl     String?        // Cloudinary video URL
  views          Int            @default(0)
  favoritesCount Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  ownerId String   @db.ObjectId
  owner   User     @relation(fields: [ownerId], references: [id])

  bookings Booking[]
  reviews  Review[]
  savedBy  SavedProperty[]

  @@index([city])
  @@index([area])
  @@index([price])
  @@index([propertyType])
  @@index([subcategory])
  @@index([createdAt])
  @@index([views])
  @@index([favoritesCount])
  @@index([isApproved])
  @@index([status])
  @@index([isApproved, status, views])
  @@index([isApproved, status, createdAt])
  @@index([isApproved, status, area])
}

// ─── NextAuth Required Models ─────────────────────────

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Supporting Models ────────────────────────────────

model Booking {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  propertyId String   @db.ObjectId
  visitDate  DateTime?
  message    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  rating     Int
  comment    String?
  userId     String   @db.ObjectId
  propertyId String   @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model SavedProperty {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  propertyId String   @db.ObjectId
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  title       String
  description String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
